module jkff (input reset, input Clk, input j,input k,output reg q, output qnot);
assign qnot =~q;
always @(posedge , clk)
if (reset) q< = 1b0; else
 case ({j,k})
2'b00: q<=q;
2'b01: q<=1'b0;
2'b10: q<=1'b1;
2'b11: q<=~q;
end case
end module

