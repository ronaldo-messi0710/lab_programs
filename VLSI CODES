VERILOG CODE FOR EXP 32 BIT ALU

'timescale 1ns|1ps.
module alu-32 bits (
input [31:0] A,
input [31:0]B,
input [3:0] ALU_Sel,
Output reg [31:0] ALU_out,
output zero 
);
assign zero= (ALU_out == 32'b0);
always@ (*)begin
case (ALU_Sel)
4'b0000: ALU_Out = A+B;
4'b0001: ALU_Out = A-B;
4'b0010: ALU_out = A&B;
4'b0011: ALU_out = AIB;
4'b0100: ALU_out = A^B;
4'b0101: ALU_out = ~A;
4'b0110: ALU_out = A<<1;
4'b0111:ALU_out = A>>1;
4'b1000 ALU-out = (A<B)? 32'd1:32'd0;
default : ALU_out = 32'b0;
endcase
end
endmodule

