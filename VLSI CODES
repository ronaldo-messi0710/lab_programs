module four_bit_adder(a,b,c0,s,c4);
input [3:0]a,b;
input c0;
output [3:0]s;
output c4;
wire c1,c2,c3;
full adder fa0(a[0],b[0],co,s[0],c1);
full adder fa1(a[1],b[1],c1,s[1],c2);
full adder fa2(a[2],b[2],c2,s[2],c3);
full adder fa3(a[3],b[3],c3,s[3],c4);
endmodule

module full adder(a,b,ci,s,co);
input a,b,ci;
output s,c0;
assign s=a^b^ci;
assign c0=(a&b)(b&ci)|(a&ci);
endmodule

