#EXPT-4
data = [
    ["High", "Good", "Yes"],
    ["High", "Poor", "No"],
    ["Low", "Good", "No"],
    ["High", "Good", "Yes"]
]
def find_s(data):
    s = None
    for e in data:
        if e[-1] == "Yes":
            if s is None:
                s = e[:-1]
            else:
                for i in range(len(s)):
                    if s[i] != e[i]:
                        s[i] = "?"
    return s
def candidate_elimination(data):
    n = len(data[0]) - 1
    S = ["ϕ"] * n
    G = [["?"] * n]
    values = [
        ["High", "Low"],
        ["Good", "Poor"]
    ]
    for e in data:
        x, label = e[:-1], e[-1]
        if label == "Yes":
            if S[0] == "ϕ":
                S = x.copy()
            else:
                for i in range(n):
                    if S[i] != x[i]:
                        S[i] = "?"
        else:
            G_new = []
            for g in G:
                for i in range(n):
                    if g[i] == "?":
                        for v in values[i]:
                            if v != x[i]:
                                h = g.copy()
                                h[i] = v
                                G_new.append(h)
            G = G_new
    return S, G
print("Find-S Hypothesis:", find_s(data))
S, G = candidate_elimination(data)
print("Specific Hypothesis S:", S)
print("General Hypothesis G:", G)

