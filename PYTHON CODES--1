#EXPT-6
import math, random
from collections import Counter, defaultdict
def entropy(d):
    return -sum(p/len(d)*math.log2(p/len(d)) for p in Counter(r[-1] for r in d).values())
def split(d, f):
    g = defaultdict(list)
    for r in d: g[r[f]].append(r)
    return g.values()
def id3(d, fs):
    lbls = [r[-1] for r in d]
    if len(set(lbls)) == 1 or not fs: return Counter(lbls).most_common(1)[0][0]
    b = max(fs, key=lambda f: entropy(d) - sum(len(s)/len(d)*entropy(s) for s in split(d, f)))
    return {b: {v: id3([r for r in d if r[b]==v], [f for f in fs if f!=b]) for v in {r[b] for r in d}}}
def predict(tree, row):
    return tree if not isinstance(tree, dict) else predict(tree[next(iter(tree))].get(row[next(iter(tree))], "?"), row)
data = [['Sunny','Hot','No'],['Sunny','Cool','No'],['Rainy','Cool','Yes'],
        ['Rainy','Hot','Yes'],['Cloudy','Hot','Yes'],['Cloudy','Cool','Yes']]
random.seed(42); random.shuffle(data)
train, test = data[:4], data[4:]
tree = id3(train, [0, 1])
print("Tree:", tree)
for row in test:
    p = predict(tree, row)
    print(f"  {'✓' if p==row[-1] else '✗'} {row[0]},{row[1]} → {p} (actual: {row[-1]})")


