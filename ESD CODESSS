EXP7  
AREA SEARCH1, CODE, READONLY 
        ENTRY 
        EXPORT __main 
 
__main 
        MOV r5,#2 
        MOV r0,#0          ; zero count 
        MOV r1,#0          ; one count 
 
        LDR r2, =VALUE1 
        LDR r2, [r2] 
 
SECOND 
        MOV r3,#32 
 
NEXT 
        MOVS r2,r2,ROR #1 
        BLO ZERO 
 
        ADD r1,r1,#1 
        B LAST 
 
ZERO 
        ADD r0,r0,#1 
 
LAST 
        SUBS r3,r3,#1 
        BNE NEXT 
 
        LDR r2, =VALUE2 
        LDR r2, [r2] 
 
        SUBS r5,r5,#1 
        BNE SECOND 
 
STOP 
        B STOP 
 
VALUE1 
        DCD 0x1234567A 
 
VALUE2 
        DCD 0x1234567A 
 
        END 

