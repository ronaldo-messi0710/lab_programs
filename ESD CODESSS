AREA LARGEST, CODE, READONLY 
        ENTRY 
        EXPORT __main  
__main 
        MOV R5, #6              ; INITIALISE COUNTER TO 6 (i.e. N=7) 
        LDR R1, =VALUE1         ; LOAD ADDRESS OF ARRAY 
        LDR R2, [R1], #4        ; LOAD FIRST ELEMENT  
LOOP 
        LDR R4, [R1], #4        ; LOAD NEXT ELEMENT 
        CMP R2, R4              ; COMPARE 
        BHI LOOP1               ; IF R2 > R4, SKIP UPDATE 
        MOV R2, R4              ; ELSE UPDATE MAX  
LOOP1 
        SUBS R5, R5, #1         ; DECREMENT COUNTER 
        CMP R5, #0 
        BNE LOOP 
        LDR R4, =RESULT         ; LOAD RESULT ADDRESS 
        STR R2, [R4]            ; STORE RESULT 
 
        NOP 
        NOP 
        NOP 
 
VALUE1 
        DCD 0x44444444 
        DCD 0x22222222 
        DCD 0x11111111 
        DCD 0x33333333 
        DCD 0xAAAAAAAA 
        DCD 0x88888888 
        DCD 0x99999999 
 
        AREA DATA2, DATA, READWRITE 
RESULT  DCD 0x0 
 
        END 

