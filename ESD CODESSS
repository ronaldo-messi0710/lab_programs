8TH ONE                                                                                                                                                                                                    AREA SEARCH1, CODE, READONLY
ENTRY
EXPORT __main

__main
    MOV r5,#2          ; Counter for 2 memory locations
    MOV r0,#0          ; Count of zeros
    MOV r1,#0          ; Count of ones

    LDR r2, VALUE1     ; Load first value

SECOND
    MOV r3,#32         ; 32 bits to check

NEXT
    MOVS r2,r2,ROR #1  ; Rotate right by 1 bit
    BLO ZERO           ; If carry = 0, bit is zero

    ADD r1,r1,#1       ; Increment ones count
    B LAST

ZERO
    ADD r0,r0,#1       ; Increment zeros count

LAST
    SUBS r3,r3,#1      ; Decrement bit counter
    BNE NEXT           ; Repeat until 32 bits checked

    LDR r2, VALUE2     ; Load second value
    SUBS r5,r5,#1      ; Decrement memory-location counter
    BNE SECOND         ; Repeat for second value

STOP
    B STOP

VALUE1 DCD 0x1234567A ; First memory location
VALUE2 DCD 0x1234567A ; Second memory location

END
